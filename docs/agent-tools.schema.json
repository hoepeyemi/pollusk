{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Boscopan Agent tools (blockchain abstraction)",
  "description": "Boscopan: structured tool schema for AI agents. These tools are the only interface to Web3/CRE; the server handles RPC, contracts, and x402.",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["create_alert", "list_alerts", "get_price", "cancel_alert", "run_alerts_check"],
      "description": "Tool / intent name"
    },
    "params": {
      "type": "object",
      "description": "Intent-specific parameters",
      "oneOf": [
        {
          "description": "create_alert — requires x402 payment; server returns 402 then agent calls POST /alerts",
          "properties": {
            "asset": { "type": "string", "enum": ["BTC", "ETH", "LINK"] },
            "condition": { "type": "string", "enum": ["gt", "lt", "gte", "lte"] },
            "target": { "type": "number", "description": "Target price USD" }
          },
          "required": ["asset", "condition", "target"]
        },
        {
          "description": "list_alerts — requires X-Agent-Wallet or params.payer",
          "properties": { "payer": { "type": "string", "description": "Wallet address" } }
        },
        {
          "description": "get_price — optional asset (BTC|ETH|LINK); omit for all prices",
          "properties": { "asset": { "type": "string", "enum": ["BTC", "ETH", "LINK"] } }
        },
        {
          "description": "cancel_alert — requires payer; alert_id or alert_index (1-based)",
          "properties": {
            "payer": { "type": "string" },
            "alert_id": { "type": "string" },
            "alert_index": { "type": "integer", "minimum": 1 }
          }
        },
        {
          "description": "run_alerts_check — run alerts check now (same as CRE cron); no params",
          "properties": {},
          "required": []
        }
      ]
    }
  },
  "required": ["intent"]
}

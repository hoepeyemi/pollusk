# Server: agent chat + x402 payment
# Reactivity: Somnia reactivity service (subscriptions, cron, run-check, write-on-chain)

# SERVER:
PORT=3000
X402_RECEIVER_ADDRESS=your_registry_contract
X402_FACILITATOR_URL=https://x402.org/facilitator
OPENAI_API_KEY=your_openai_api_key
AGENT_WALLET_PRIVATE_KEY=your_private_key
# Optional: scheduled agent interval in ms (e.g. 900000 = 15 min); 0 or unset = disabled
# SCHEDULED_AGENT_INTERVAL_MS=900000
# Optional: base URL of reactivity service; server POSTs to {base}/run-check and {base}/write-alert
# REACTIVITY_RUN_CHECK_URL=http://localhost:3001

# Hardhat (Somnia testnet):
# RPC_URL=https://dream-rpc.somnia.network/
# PRIVATE_KEY=your_private_key  # or DEPLOYER_PRIVATE_KEY
# STT_TOKEN_ADDRESS=0x7f89af8b3c0A68F536Ff20433927F4573CF001A3

# REACTIVITY SERVICE (npm run dev:reactivity):
# RULE_REGISTRY_ADDRESS= or X402_RECEIVER_ADDRESS= (same as server)
# RULE_REQUEST_EMITTER_ADDRESS= (from npm run deploy:reactivity)
# REACTIVITY_CRON_INTERVAL_MS=300000
# REACTIVITY_RULE_TTL=1800
# REACTIVITY_PORT=3001
# PUSHOVER_USER_KEY_VAR= and PUSHOVER_API_KEY_VAR= (for notifications)
# REACTIVITY_WRITER_PRIVATE_KEY= (optional; for POST /write-alert to emit on-chain)